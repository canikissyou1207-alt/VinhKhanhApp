<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vinh Khanh Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background:#f8f9fa; }
        .table img { object-fit:cover; border-radius:8px; }
        .page-header { background:white; border-radius:16px; padding:24px; box-shadow:0 4px 18px rgba(0,0,0,.06); margin-bottom:20px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="AdminPois" asp-action="Index">Vinh Khanh Admin</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="AdminPois" asp-action="Index">POI</a>
                <a class="nav-link" href="/swagger">Swagger</a>
                <a class="nav-link" href="/api/POIs">API JSON</a>
            </div>
        </div>
    </nav>

    <main class="container pb-4">
        @if (TempData["Success"] is string message)
        {
            <div class="alert alert-success">@message</div>
        }
        @RenderBody()
    </main>
</body>
</html>
