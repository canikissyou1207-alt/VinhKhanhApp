@model PoiAdminEditViewModel
@{
    ViewData["Title"] = "Sửa POI";
}

<div class="page-header">
    <h1 class="h3 mb-1">Sửa POI #@Model.POIID</h1>
    <div class="text-muted">Bạn có thể thay ảnh và audio trực tiếp tại đây.</div>
</div>

<form asp-action="Edit" asp-route-id="@Model.POIID" method="post" enctype="multipart/form-data" class="card border-0 shadow-sm">
    <input asp-for="POIID" type="hidden" />
    <div class="card-body row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="CategoryID" class="form-label"></label>
            <input asp-for="CategoryID" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Priority" class="form-label"></label>
            <input asp-for="Priority" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Latitude" class="form-label"></label>
            <input asp-for="Latitude" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Longitude" class="form-label"></label>
            <input asp-for="Longitude" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Radius" class="form-label"></label>
            <input asp-for="Radius" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Description_VN" class="form-label"></label>
            <textarea asp-for="Description_VN" class="form-control" rows="5"></textarea>
        </div>
        <div class="col-12">
            <label asp-for="Description_EN" class="form-label"></label>
            <textarea asp-for="Description_EN" class="form-control" rows="5"></textarea>
        </div>
        <div class="col-md-6">
            <label class="form-label">Ảnh hiện tại</label>
            <div>
                @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath))
                {
                    <img src="@Model.ExistingImagePath" alt="current image" style="max-width:260px; border-radius:12px;" />
                }
                else
                {
                    <div class="text-muted">Chưa có ảnh.</div>
                }
            </div>
            <label asp-for="ImageFile" class="form-label mt-2"></label>
            <input asp-for="ImageFile" type="file" accept="image/*" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Audio hiện tại</label>
            <div>
                @if (!string.IsNullOrWhiteSpace(Model.ExistingAudioUrl))
                {
                    <audio controls preload="none" style="width:100%; max-width:360px;">
                        <source src="@Model.ExistingAudioUrl" />
                    </audio>
                }
                else
                {
                    <div class="text-muted">Chưa có audio, app sẽ dùng TTS.</div>
                }
            </div>
            <label asp-for="AudioFile" class="form-label mt-2"></label>
            <input asp-for="AudioFile" type="file" accept="audio/*" class="form-control" />
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</form>
