@model IEnumerable<VinhKhanhApi.Models.UserPosition>

@{
    Layout = null; // Để nó không bị dính giao diện mặc định của ASP.NET
}

<!DOCTYPE html>
<html>
<head>
    <title>AdminPois - Active Users</title>
    <!-- Nhúng Bootstrap để có giao diện bảng đẹp luôn -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .admin-card {
            border-radius: 0;
            border: 2px solid #000;
            margin-top: 50px;
        }

        .table thead {
            background-color: #000;
            color: #fff;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="card admin-card shadow-lg">
            <div class="card-header bg-black text-white p-3">
                <h4 class="mb-0">ADMINPOIS - MONITORING</h4>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-hover">
                    <thead>
                        <tr>
                            <th>Mẫu Máy</th>
                            <th>ID Thiết Bị</th>
                            <th>Ngôn Ngữ</th>
                            <th>Tọa Độ (Lat, Lng)</th>
                            <th>Hoạt Động Cuối</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var user in Model)
                            {
                                <tr>
                                    <td><strong>@user.DeviceModel</strong></td>
                                    <td><code class="text-dark">@user.DeviceId</code></td>
                                    <td><span class="badge bg-dark">@user.CurrentLanguage</span></td>
                                    <td>@user.Latitude.ToString("F5"), @user.Longitude.ToString("F5")</td>
                                    <td>@user.LastUpdate.ToString("HH:mm:ss")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center p-5 text-muted italic">Đang đợi thiết bị kết nối...</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Tự động tải lại trang sau 5 giây để cập nhật vị trí mới nhất
        setTimeout(function() { window.location.reload(); }, 5000);
    </script>

</body>
</html>